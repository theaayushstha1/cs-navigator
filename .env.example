# =============================================================================
# CSNavigator v2.0 (ADK) - Environment Variables Template
# =============================================================================
# Copy this to .env and fill in your actual values
# NEVER commit .env with real credentials!
#
# For Cloud Run: secrets are stored in Secret Manager (see deploy-cloudrun.sh)
# =============================================================================

# --- Vertex AI Agent (ADK) ---
USE_VERTEX_AGENT=true
ADK_APP_NAME=cs_navigator_unified

# For local development:
ADK_BASE_URL=http://127.0.0.1:8080

# For Cloud Run (auto-set during deployment):
# ADK_BASE_URL=https://csnavigator-adk-xxxxx-uc.a.run.app

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT=<your-gcp-project-id>

# --- Database (AWS RDS MySQL) ---
DATABASE_URL=mysql+pymysql://user:password@host:3306/dbname

# --- Authentication ---
JWT_SECRET=<generate-64-char-random-string>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=240

# --- Admin Account ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<strong-password>

# --- OpenAI (TTS voice feature only) ---
OPENAI_API_KEY=<your-openai-key>

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://127.0.0.1:3000,http://127.0.0.1:5173

# --- Legacy Pinecone (optional) ---
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=
# PINECONE_ENV=
# PINECONE_NAMESPACE=docs
