# =============================================================================
# CSNavigator v2.0 (ADK) - Environment Variables
# =============================================================================
# Copy this to .env and fill in your values

# --- Database ---
DATABASE_URL=mysql+pymysql://user:password@host:3306/dbname

# --- Authentication ---
JWT_SECRET=<generate-a-random-64-char-string>
ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=<strong-password>

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT=<your-gcp-project-id>
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# --- Vertex AI Search (Knowledge Base) ---
VERTEX_AI_DATASTORE_ID=projects/<project>/locations/us/collections/default_collection/dataStores/<datastore-id>
GCS_KB_BUCKET=<gcs-bucket-name>

# --- ADK Agent ---
ADK_BASE_URL=http://127.0.0.1:8080
ADK_APP_NAME=cs_navigator_unified
VERTEX_AI_MODEL=gemini-2.0-flash

# --- OpenAI (used for TTS only) ---
OPENAI_API_KEY=<your-openai-key>

# --- Legacy (optional, only if using Pinecone RAG fallback) ---
# PINECONE_API_KEY=
# PINECONE_ENV=
# PINECONE_INDEX_NAME=
# PINECONE_NAMESPACE=docs
